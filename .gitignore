# Model training - large files (not for Git)
# Training images (users should download their own)
layout-model-training/data/yearbook/images/*.jpg
layout-model-training/data/yearbook/images/*.png

# Trained model weights — tracked via Git LFS
# Exclude all except the best-performing model (yearbook-clean60, 70% AP50)
layout-model-training/outputs/**/model_*.pth
!layout-model-training/outputs/yearbook-clean60/fast_rcnn_R_50_FPN/model_final.pth

# Training logs and test outputs
layout-model-training/scripts/*.log
layout-model-training/test_results/

# Intermediate visualization / debug artifacts
layout-model-training/detection_*.jpg
layout-model-training/detection_*.png
layout-model-training/v4-460px-Yearbook-Page-Ideas-Step-11.jpg
layout-model-training/Screenshot *.png
layout-model-training/outputs/
!layout-model-training/outputs/yearbook-clean60/fast_rcnn_R_50_FPN/model_final.pth
!layout-model-training/outputs/yearbook-clean60/fast_rcnn_R_50_FPN/config.yaml
outputs/
*.log

# SLURM job logs
logs/
layout-model-training/logs/

# Generated presentations
*.pptx

# Experiment outputs — ignore raw intermediate images, keep demo outputs and JSONs
layout-model-training/experiments/portrait_matches/*_numbered.jpg
layout-model-training/experiments/portrait_matches/*_annotated.jpg
layout-model-training/experiments/portrait_matches/*.html

